<%- include('../partials/app-head', { title: 'Neues Geschenk – GeschenkKiste' }) %>

<div class="mb-6">
  <a href="/gifts" class="app-link">← zurück</a>
</div>

<div class="mb-8">
  <h1 class="app-h1">➕ Neues Geschenk</h1>
  <p class="app-subtle mt-1">Füge ein Geschenk zum Katalog hinzu.</p>
</div>

<%
  const preId = (typeof preselectedInterestId !== 'undefined' && preselectedInterestId)
    ? String(preselectedInterestId)
    : null;
%>

<section class="app-panel">
  <div class="app-panel-header">
    <h2 class="app-panel-title">Geschenk anlegen</h2>
  </div>

  <div class="app-panel-body">
    <form action="/gifts" method="POST" enctype="multipart/form-data" class="space-y-6">

      <div>
        <label class="block text-white font-semibold mb-2">Name *</label>
        <input type="text" name="title" required class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20
                      focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="z.B. Gutschein">
      </div>

      <div>
        <label class="block text-white font-semibold mb-2">Beschreibung</label>
        <textarea name="description" rows="3" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20
                         focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="Beschreibung des Anlasses..."></textarea>
      </div>

      <div>
        <label class="block text-white font-semibold mb-2">Link</label>
        <input type="url" name="link" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20" placeholder="https://...">
      </div>

      <div>
        <label class="block text-white font-semibold mb-2">Interessenskategorien</label>

        <% if (!interests || interests.length === 0) { %>
        <p class="text-sm text-white/80 mb-3">Noch keine Kategorien vorhanden. Lege unten eine neue an.</p>
        <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 border border-white/15 rounded-lg p-4 bg-white/10 max-h-64 overflow-y-auto">
          <% interests.forEach(interest => { 
                 const isPre = preId && String(interest._id) === preId;
            %>
          <label class="flex items-center gap-2 p-2 rounded hover:bg-white/10 transition cursor-pointer">
            <input type="checkbox" name="interests" value="<%= interest._id %>" class="h-4 w-4" <%= isPre ? 'checked' : '' %>>
            <span class="text-sm font-semibold text-white"><%= interest.icon %> <%= interest.name %></span>
          </label>
          <% }) %>
        </div>
        <% } %>

        <div class="mt-3 p-4 rounded-lg border border-dashed border-white/20 bg-white/10">
          <p class="text-sm font-semibold text-white mb-3">➕ Neue Kategorie direkt anlegen</p>
          <div class="flex gap-2 items-center">
            <input type="text" name="newInterestName" placeholder="Name (z.B. Technik)" class="flex-1 px-3 py-2 text-sm rounded-lg bg-white text-slate-900 border border-white/20">

            <div class="w-28">
              <%- include('../partials/icon-picker-field', {
                name: 'newInterestIcon',
                value: '',
                fallback: '🎁',
                inputClass: 'w-full px-3 py-2 text-sm rounded-lg bg-white text-slate-900 border border-white/20',
                buttonClass: 'btn-surface'
              }) %>
            </div>
          </div>
          <p class="text-xs text-white/80 mt-2">
            Wird beim Speichern erstellt und dem Geschenk zugewiesen.
          </p>
        </div>
      </div>

      <div>
        <label class="block text-white font-semibold mb-2">Bilder (max. 10)</label>
        <input type="file" name="images" multiple accept="image/*" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20">
      </div>

      <div class="app-item">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" name="isPublic" value="true" class="check-on-blue mt-0.5">
          <div>
            <span class="text-white font-semibold block mb-1">🌍 Geschenk öffentlich machen</span>
            <p class="text-sm text-white/80">Wenn aktiviert, wird das neue Geschenk öffentlich (Katalog).</p>
          </div>
        </label>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button type="submit" class="btn-primary flex-1 py-3">Speichern</button>
        <a href="/gifts" class="btn-surface flex-1 justify-center py-3">Abbrechen</a>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/app-foot') %>