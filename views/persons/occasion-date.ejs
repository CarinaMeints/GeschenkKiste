<%- include('../partials/app-head', { title: `Datum bearbeiten – ${person.name} – GeschenkKiste` }) %>

<%
  const occ = link.occasion;
  const movable = !(occ.day != null && occ.month != null) && occ.isBirthday !== true;

  const y = (typeof requestedYear === 'number' && !Number.isNaN(requestedYear))
    ? requestedYear
    : (link.customYear || new Date().getFullYear());

  const returnTo = (locals.returnTo && String(locals.returnTo).startsWith('/'))
    ? String(locals.returnTo)
    : ('/persons/' + person._id + '/occasions');

  function existingDateValue() {
    if (link.customYear === y && link.customMonth && link.customDay) {
      const yyyy = String(link.customYear).padStart(4, '0');
      const mm = String(link.customMonth).padStart(2, '0');
      const dd = String(link.customDay).padStart(2, '0');
      return `${yyyy}-${mm}-${dd}`;
    }
    const yyyy = String(y).padStart(4, '0');
    return `${yyyy}-01-01`;
  }
%>

<div class="mb-6">
  <a href="<%= returnTo %>" class="app-link">
    ← Zurück
  </a>
</div>

<div class="mb-8">
  <h1 class="app-h1">✏️ Datum bearbeiten</h1>
  <p class="app-subtle mt-1">
    <%= occ.icon %> <%= occ.name %> – <%= person.name %>
  </p>
</div>

<section class="app-panel">
  <div class="app-panel-header">
    <h2 class="app-panel-title">Datum setzen</h2>
    <span class="app-panel-count"><%= y %></span>
  </div>

  <div class="app-panel-body">
    <% if (!movable) { %>
    <div class="app-item">
      <p class="text-sm font-semibold text-white">
        Für diesen Anlass wird kein benutzerdefiniertes Datum gespeichert.
      </p>
      <p class="app-item-meta mt-2">
        <% if (occ.isBirthday) { %>
        Geburtstag kommt aus dem Geburtstag der Person.
        <% } else { %>
        Festes Datum kommt aus dem Anlass (z.B. Weihnachten).
        <% } %>
      </p>

      <div class="mt-4">
        <a href="<%= returnTo %>" class="btn-surface">Zurück</a>
      </div>
    </div>
    <% } else { %>

    <form action="/persons/<%= person._id %>/occasions/<%= link._id %>/date?returnTo=<%= encodeURIComponent(returnTo) %><%= y ? `&year=${encodeURIComponent(String(y))}` : '' %>" method="POST" class="space-y-4">
      <input type="hidden" name="_method" value="PATCH">
      <div>
        <label class="block text-white font-semibold mb-2">Datum *</label>
        <input type="date" name="date" required value="<%= existingDateValue() %>" class="w-full px-4 py-2.5 border border-white/20 rounded-lg bg-white text-slate-900">
        <p class="text-xs text-white/80 mt-2">
          Vorbelegung: <span class="font-semibold">01.01.<%= y %></span>, damit das Jahr stimmt.
          Bitte Tag/Monat anpassen.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button type="submit" class="btn-primary flex-1">Speichern</button>
        <a href="<%= returnTo %>" class="btn-surface flex-1 justify-center">Abbrechen</a>
      </div>
    </form>

    <% } %>
  </div>
</section>

<%- include('../partials/app-foot') %>