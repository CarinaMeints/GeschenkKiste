<div class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50"
     data-dc-modal>
  <div class="app-modal w-full max-w-lg rounded-xl shadow-xl mx-4">
    <div class="app-modal-header px-6 py-4 flex items-center justify-between">
      <h3 class="app-modal-title text-lg font-bold" data-dc-title>Bestätigen</h3>
      <button type="button" class="app-modal-close text-xl font-bold" data-dc-close>×</button>
    </div>

    <div class="p-6 space-y-4">
      <p class="text-sm text-slate-700 font-semibold" data-dc-message>
        Möchtest du das wirklich löschen?
      </p>

      <div class="flex justify-end gap-3 pt-2">
        <button type="button" class="btn-surface" data-dc-cancel>Abbrechen</button>
        <button type="button" class="btn-primary" data-dc-ok>Ja, löschen</button>
      </div>
    </div>
  </div>
</div>