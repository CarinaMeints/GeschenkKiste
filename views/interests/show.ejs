<%- include('../partials/app-head', { title: `${interest.name} – Interesse – GeschenkKiste` }) %>

<div class="mb-6">
  <a href="/interests" class="app-link">← zu allen Interessen</a>
</div>

<section class="app-panel mb-8">
  <div class="app-panel-header">
    <div class="min-w-0">
      <h1 class="app-panel-title truncate">
        <%= interest.icon || '🎁' %> <%= interest.name %>
      </h1>
      <p class="text-xs text-white/80 mt-1 font-semibold">
        <%= interest.isPublic ? '🌍 Katalog (read-only)' : 'Eigene Kategorie' %>
      </p>
    </div>

    <div class="flex gap-2 shrink-0">
      <a href="/gifts/new?interestId=<%= interest._id %>" class="btn-surface">➕ Geschenk</a>

      <% if (canEdit) { %>
      <a href="/interests/<%= interest._id %>/edit" class="btn-surface">✏️ Bearbeiten</a>

      <form action="/interests/<%= interest._id %>" method="POST" data-dc-confirm data-dc-title="Interesse wirklich löschen?" data-dc-message="Möchtest du das Interesse „<%= interest.name %>“ wirklich löschen? Verknüpfungen zu Personen und eigenen Geschenken werden entfernt." data-dc-ok="Ja, löschen">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn-surface" style="border-color:#fecaca;color:#b91c1c;">
          🗑️
        </button>
      </form>
      <% } %>
    </div>
  </div>

  <div class="app-panel-body">
    <% if (interest.description) { %>
    <div class="app-item">
      <p class="text-sm font-semibold text-white mb-1">Beschreibung</p>
      <p class="text-sm text-white/90"><%= interest.description %></p>
    </div>
    <% } else { %>
    <p class="text-sm text-white/80">Keine Beschreibung hinterlegt.</p>
    <% } %>
  </div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <section class="app-panel">
    <div class="app-panel-header">
      <h2 class="app-panel-title">👥 Personen</h2>
      <span class="app-panel-count"><%= (persons || []).length %></span>
    </div>

    <div class="app-panel-body">
      <% if (!persons || persons.length === 0) { %>
      <p class="text-sm text-white/80">Keine Personen haben dieses Interesse.</p>
      <% } else { %>
      <div class="space-y-3">
        <% persons.forEach(p => { %>
        <a href="/persons/<%= p._id %>" class="app-item app-item-clickable block">
          <div class="font-semibold text-white truncate">👤 <%= p.name %></div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </section>

  <section class="app-panel">
    <div class="app-panel-header">
      <h2 class="app-panel-title">🎁 Geschenke</h2>
      <span class="app-panel-count"><%= (gifts || []).length %></span>
    </div>

    <div class="app-panel-body">
      <% if (!gifts || gifts.length === 0) { %>
      <p class="text-sm text-white/80">Diesem Interesse sind keine Geschenke zugeordnet.</p>
      <% } else { %>
      <div class="space-y-3">
        <% gifts.forEach(g => { %>
        <a href="/gifts/<%= g._id %>" class="app-item app-item-clickable block">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="font-semibold text-white truncate"><%= g.title %></div>
              <div class="text-xs text-white/80 mt-1">
                <%= g.isPublic ? '🌍 Katalog' : 'Eigener Eintrag' %>
                · <%= (g.usageCount || 0) %>× verwendet
              </div>
            </div>
            <span class="text-xs text-white/80 font-semibold shrink-0">→</span>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </section>

</div>

<div class="fixed inset-0 hidden items-center justify-center bg-black/50 z-50" data-dc-modal>
  <div class="app-modal w-full max-w-lg rounded-xl shadow-xl mx-4">
    <div class="app-modal-header px-6 py-4 flex items-center justify-between">
      <h3 class="app-modal-title text-lg font-bold" data-dc-title>Bestätigen</h3>
      <button type="button" class="app-modal-close text-xl font-bold" data-dc-close>×</button>
    </div>
    <div class="p-6 space-y-4">
      <p class="text-sm text-slate-700 font-semibold" data-dc-message>…</p>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" class="btn-surface" data-dc-cancel>Abbrechen</button>
        <button type="button" class="btn-primary" data-dc-ok>Ja, löschen</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/delete-confirm.js" defer></script>

<%- include('../partials/app-foot') %>