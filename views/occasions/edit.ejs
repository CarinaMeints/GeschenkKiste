<%- include('../partials/app-head', { title: `${occasion.name} bearbeiten – GeschenkKiste` }) %>

<%
  const months = ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
%>

<div class="mb-6">
  <a href="/occasions/<%= occasion._id %>" class="app-link">← Zurück</a>
</div>

<div class="mb-8">
  <h1 class="app-h1">✏️ Anlass bearbeiten</h1>
</div>

<section class="app-panel">
  <div class="app-panel-header">
    <h2 class="app-panel-title"><%= occasion.icon || '🎉' %> <%= occasion.name %></h2>
  </div>

  <div class="app-panel-body">
    <form action="/occasions/<%= occasion._id %>" method="POST" class="space-y-8">
      <input type="hidden" name="_method" value="PUT">

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-white font-semibold mb-2">Name *</label>
          <input type="text" name="name" required value="<%= occasion.name %>" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20
                        focus:outline-none focus:ring-2 focus:ring-white/40">
        </div>

        <div>
          <label class="block text-white font-semibold mb-2">Icon</label>
          <%- include('../partials/icon-picker-field', {
            name: 'icon',
            value: occasion.icon,
            fallback: '🎉',
            inputClass: 'w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20'
          }) %>
          <p class="text-xs text-white/80 mt-2">Wähle dein Icon über "😊".</p>
        </div>
      </div>

      <div>
        <label class="block text-white font-semibold mb-2">Beschreibung</label>
        <textarea name="description" rows="3" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20
                         focus:outline-none focus:ring-2 focus:ring-white/40"><%= occasion.description || '' %></textarea>
      </div>

      <div class="app-item">
        <p class="text-sm font-semibold text-white mb-3">Festes Datum</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-white/80 font-semibold mb-1">Tag</label>
            <input type="number" name="day" min="1" max="31" value="<%= occasion.day || '' %>" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20">
          </div>

          <div>
            <label class="block text-xs text-white/80 font-semibold mb-1">Monat</label>
            <select name="month" class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 border border-white/20">
              <option value="">-- Monat wählen --</option>
              <% months.forEach((m, idx) => { %>
              <option value="<%= idx + 1 %>" <%= occasion.month === (idx + 1) ? 'selected' : '' %>><%= m %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <p class="text-xs text-white/80 mt-2">
          Für bewegliche Anlässe kann Tag/Monat leer bleiben → Datum wird pro Jahr gepflegt.
        </p>
      </div>

      <div class="app-item">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="isRecurring" value="true" <%= occasion.isRecurring ? 'checked' : '' %> class="check-on-blue">
          <span class="text-white font-semibold">Wiederkehrender Anlass (jährlich)</span>
        </label>
      </div>

      <% if (typeof persons !== 'undefined' && persons && persons.length) { %>
      <div>
        <h3 class="text-white font-bold mb-2">👥 Personen zuordnen (optional)</h3>
        <p class="text-xs text-white/80 mb-3">
          Hinweis: Für Katalog-Anlässe erfolgt die Zuordnung auf der Anlass-Detailseite.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 border border-white/15 rounded-lg p-4 bg-white/10 max-h-80 overflow-y-auto">
          <% persons.forEach(p => { 
                 const checked = assignedPersonIds && assignedPersonIds.has(String(p._id));
            %>
          <label class="flex items-center gap-2 p-2 rounded hover:bg-white/10 transition cursor-pointer">
            <input type="checkbox" name="personIds" value="<%= p._id %>" class="check-on-blue" <%= checked ? 'checked' : '' %>>
            <span class="text-sm font-semibold text-white"><%= p.name %></span>
          </label>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="flex flex-col sm:flex-row gap-3">
        <button type="submit" class="btn-primary flex-1 py-3">Speichern</button>
        <a href="/occasions/<%= occasion._id %>" class="btn-surface flex-1 justify-center py-3">Abbrechen</a>
      </div>

    </form>
  </div>
</section>

<%- include('../partials/app-foot') %>